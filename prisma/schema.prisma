generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?
  role             String    @default("brand")
  credits          Int       @default(5)
  brandVerified    Boolean   @default(false)
  brandVerifiedAt  DateTime?
  createdAt        DateTime  @default(now())
  sessions         Session[]
  accounts         Account[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model CreditTransaction {
  id        String   @id @default(cuid())
  userId    String
  type      String
  amount    Int
  createdAt DateTime @default(now())
}
model Influencer {
  id           String   @id @default(cuid())
  name         String
  handle       String
  location     String
  niche        String
  platform     String
  followers    String
  engagement   String
  score        Int
  rate         String
  initials     String
  about        String?
  email        String?
  phone        String?
  verified         Boolean  @default(false)
  userId           String?
  followersPublic  Boolean  @default(true)
  createdAt        DateTime @default(now())
  @@unique([handle])
}

model UnlockedContact {
  id           String   @id @default(cuid())
  userId       String
  influencerId String
  createdAt    DateTime @default(now())

  @@unique([userId, influencerId])
  
}
model Campaign {
  id           String   @id @default(cuid())
  brandId      String
  title        String
  description  String
  niche        String
  platform     String
  budget       String
  deadline     String
  slots        Int      @default(1)
  minFollowers String   @default("1K")
  location     String   @default("Pan India")
  status       String   @default("Open")
  createdAt    DateTime @default(now())
  applications CampaignApplication[]
}

model CampaignApplication {
  id           String   @id @default(cuid())
  campaignId   String
  userId       String
  status       String   @default("pending")
  createdAt    DateTime @default(now())
  campaign     Campaign @relation(fields: [campaignId], references: [id])

  @@unique([campaignId, userId])
}

model CollaborationRequest {
  id           String   @id @default(cuid())
  fromUserId   String
  toUserId     String?
  influencerId String?
  brandId      String?
  message      String?
  status       String   @default("pending")
  createdAt    DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  userId    String?
  name      String
  email     String
  subject   String
  message   String
  status    String   @default("unread")
  createdAt DateTime @default(now())
}

model CampaignReview {
  id           String   @id @default(cuid())
  campaignId   String
  influencerId String
  brandId      String
  rating       Int
  review       String
  campaignName String
  campaignDesc String
  namePublic   Boolean  @default(true)
  reviewPublic Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@unique([campaignId, influencerId, brandId])
}