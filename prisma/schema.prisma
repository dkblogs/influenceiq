generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?
  role             String    @default("brand")
  credits          Int       @default(5)
  brandVerified    Boolean   @default(false)
  brandVerifiedAt  DateTime?
  companyName      String?
  industry         String?
  location         String?
  website          String?
  phone            String?
  about            String?
  createdAt        DateTime  @default(now())
  sessions         Session[]
  accounts         Account[]
  influencers      Influencer[]
  notifications    Notification[]
  brandProposals   Proposal[]        @relation("BrandProposals")
  unlockedContacts UnlockedContact[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model CreditTransaction {
  id        String   @id @default(cuid())
  userId    String
  type      String
  amount    Int
  createdAt DateTime @default(now())
}
model Influencer {
  id           String   @id @default(cuid())
  name         String
  handle       String
  location     String
  gender       String?
  niche        String
  niches       String[]
  platform     String
  platforms    String[]
  followers    String
  engagement   String
  score        Int
  rate         String
  initials     String
  about        String?
  email        String?
  phone        String?
  profileImage String?
  instagramHandle      String?
  instagramVerified      Boolean   @default(false)
  instagramFollowers     Int?
  instagramBio           String?
  instagramProfilePic    String?
  instagramVerifyCode    String?
  instagramVerifyExpiry  DateTime?
  youtubeHandle          String?
  youtubeVerified        Boolean   @default(false)
  youtubeFollowers       Int?
  youtubeBio             String?
  youtubeProfilePic      String?
  youtubeVerifyCode      String?
  youtubeVerifyExpiry    DateTime?
  aiScore              Int?
  aiReportSummary      String?
  aiReportFull         String?
  aiReportGeneratedAt  DateTime?
  verified             Boolean  @default(false)
  userId           String?
  user             User?    @relation(fields: [userId], references: [id])
  followersPublic      Boolean   @default(true)
  analyticsData        String?
  analyticsUpdatedAt   DateTime?
  createdAt            DateTime  @default(now())
  portfolioItems   PortfolioItem[]
  aiReports        AiReport[]
  proposals        Proposal[]
  unlockedContacts UnlockedContact[]
  @@unique([handle])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}

model AiReport {
  id            String     @id @default(cuid())
  influencerId  String
  influencer    Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  score         Int
  summary       String
  reportFull    String     @db.Text
  createdAt     DateTime   @default(now())
}

model PortfolioItem {
  id            String     @id @default(cuid())
  influencerId  String
  influencer    Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  brandName     String
  campaignTitle String
  description   String?
  deliverables  String?
  results       String?
  mediaUrl      String?
  completedAt   DateTime?
  createdAt     DateTime   @default(now())
}

model UnlockedContact {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  influencerId String
  influencer   Influencer @relation(fields: [influencerId], references: [id])
  unlockedAt   DateTime   @default(now())
  expiresAt    DateTime   @default(now())

  @@unique([userId, influencerId])
}
model Campaign {
  id           String   @id @default(cuid())
  brandId      String
  title        String
  description  String
  niche        String
  platform     String
  platforms    String[]
  budget       String
  deadline     String
  slots        Int      @default(1)
  minFollowers String   @default("1K")
  location     String   @default("Pan India")
  status       String   @default("Open")
  createdAt    DateTime @default(now())
  applications CampaignApplication[]
}

model CampaignApplication {
  id           String   @id @default(cuid())
  campaignId   String
  userId       String
  status       String   @default("pending")
  createdAt    DateTime @default(now())
  campaign     Campaign @relation(fields: [campaignId], references: [id])

  @@unique([campaignId, userId])
}

model CollaborationRequest {
  id           String   @id @default(cuid())
  fromUserId   String
  toUserId     String?
  influencerId String?
  brandId      String?
  message      String?
  status       String   @default("pending")
  createdAt    DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  userId    String?
  name      String
  email     String
  subject   String
  message   String
  status    String   @default("unread")
  createdAt DateTime @default(now())
}

model CampaignReview {
  id           String   @id @default(cuid())
  campaignId   String
  influencerId String
  brandId      String
  rating       Int
  review       String
  campaignName String
  campaignDesc String
  namePublic   Boolean  @default(true)
  reviewPublic Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@unique([campaignId, influencerId, brandId])
}

model Proposal {
  id                  String    @id @default(cuid())
  brandId             String
  brand               User      @relation("BrandProposals", fields: [brandId], references: [id])
  influencerId        String
  influencer          Influencer @relation(fields: [influencerId], references: [id])
  status              String    @default("pending")
  campaignTitle       String
  contentType         String
  description         String    @db.Text
  deliverables        String    @db.Text
  location            String?
  timeline            String
  startDate           DateTime?
  endDate             DateTime?
  remuneration        String
  remunerationDetails String?   @db.Text
  exclusivity         Boolean   @default(false)
  revisions           Int       @default(2)
  additionalTerms     String?   @db.Text
  rounds              ProposalRound[]
  messages            ProposalMessage[]
  workspace           CampaignWorkspace?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model CampaignWorkspace {
  id             String    @id @default(cuid())
  proposalId     String    @unique
  proposal       Proposal  @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  brandId        String
  influencerId   String
  campaignTitle  String?
  status         String    @default("active")
  paymentStatus      String    @default("pending")
  paymentAmount      String?
  paymentNotes       String?   @db.Text
  paymentSentAt      DateTime?
  paymentConfirmedAt DateTime?
  milestones     WorkspaceMilestone[]
  deliverables   WorkspaceDeliverable[]
  reviews        WorkspaceReview[]
  messages       WorkspaceMessage[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model WorkspaceMilestone {
  id          String            @id @default(cuid())
  workspaceId String
  workspace   CampaignWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  title       String
  description String?           @db.Text
  dueDate     DateTime?
  status      String            @default("pending")
  completedAt DateTime?
  order       Int               @default(0)
  createdAt   DateTime          @default(now())
}

model WorkspaceDeliverable {
  id          String            @id @default(cuid())
  workspaceId String
  workspace   CampaignWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  title       String
  description String?           @db.Text
  fileUrl     String?
  status      String            @default("pending")
  feedback    String?           @db.Text
  submittedAt DateTime?
  approvedAt  DateTime?
  createdAt   DateTime          @default(now())
}

model WorkspaceReview {
  id          String            @id @default(cuid())
  workspaceId String
  workspace   CampaignWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  reviewerId  String
  reviewerRole String
  rating      Int
  comment     String            @db.Text
  createdAt   DateTime          @default(now())
}

model WorkspaceMessage {
  id          String            @id @default(cuid())
  workspaceId String
  workspace   CampaignWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  senderId    String
  senderRole  String
  message     String            @db.Text
  createdAt   DateTime          @default(now())
}

model ProposalRound {
  id                   String   @id @default(cuid())
  proposalId           String
  proposal             Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  roundNumber          Int
  submittedBy          String
  remunerationCounter  String?
  deliverablesCounter  String?  @db.Text
  timelineCounter      String?
  revisionsCounter     Int?
  notes                String?  @db.Text
  status               String   @default("pending")
  createdAt            DateTime @default(now())
}

model ProposalMessage {
  id          String   @id @default(cuid())
  proposalId  String
  proposal    Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  senderId    String
  senderRole  String
  message     String   @db.Text
  createdAt   DateTime @default(now())
}